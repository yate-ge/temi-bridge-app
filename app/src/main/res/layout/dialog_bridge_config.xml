<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Server status (read-only) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Server"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/dialogServerStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Running"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cccccc"
        android:layout_marginBottom="16dp" />

    <!-- Client connection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Brain Connection"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/dialogBrainUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="ws://192.168.1.100:8080"
        android:textSize="14sp"
        android:inputType="textUri"
        android:singleLine="true"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/dialogBtnConnect"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Connect"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/dialogBtnDisconnect"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Disconnect"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/dialogClientStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not connected"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <CheckBox
        android:id="@+id/dialogAutoConnect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Auto-connect on startup"
        android:textSize="14sp" />

</LinearLayout>
